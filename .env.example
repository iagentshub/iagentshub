# ── Variables de entorno para docker-compose ──────────────────────────────────
# Copiar este fichero como .env y ajustar los valores.
# El fichero .env NO se sube al repositorio (está en .gitignore).

# Puerto público del frontend (default 80)
PORT=80

# Secreto para firmar los tokens JWT.
# ¡CAMBIAR en producción! Generar con: openssl rand -hex 32
GAIA_AGENTS_SECRET=cambia_esto_en_produccion

# Orígenes CORS permitidos para el backend (separar con coma si hay varios).
# Con nginx como proxy no suele ser necesario, pero se deja por seguridad.
GAIA_CORS_ORIGINS=http://localhost

# Token de GitHub (Personal Access Token con permisos read-only).
# Necesario mientras los repositorios sean privados; dejar vacío cuando sean públicos.
GITHUB_TOKEN=

# Repositorios a desplegar.
BACKEND_REPO=https://github.com/iagentshub/backend.git
FRONTEND_REPO=https://github.com/iagentshub/frontend.git
SKILLS_REPO=https://github.com/iagentshub/skills.git
# Idioma de las skills públicas (subcarpeta dentro del repo de skills).
SKILLS_LANG=es

# Rutas locales para modo desarrollo (./gaia.sh start --dev).
# Por defecto apuntan a ../backend, ../frontend y ../skills (repos hermanos).
# Solo necesario si tu estructura de carpetas es diferente.
# DEV_BACKEND_REPO=/ruta/a/tu/backend
# DEV_FRONTEND_REPO=/ruta/a/tu/frontend
# DEV_SKILLS_REPO=/ruta/a/tu/skills
